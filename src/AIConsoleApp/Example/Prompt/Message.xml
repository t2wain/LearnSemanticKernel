<?xml version="1.0" encoding="UTF-8"?>
<!-- use_group and group attributes are optional -->
<chat use_group="main">
  <messages group="main">
    <!-- All system messages will be concatenated -->
    <message role="system"></message>
    <message role="system"></message>
    <message role="system"></message>
    <message role="user"></message>
    <message role="user">
      <![CDATA[
    
          ]]>
    </message>
    <message role="assistant"></message>
    <message role="developer"></message>
    <message role="user">
      <text></text>
      <image></image>
    </message>
  </messages>
  <messages group="alt">
    <!-- Not used by the current session -->
    <message role="system"></message>
    <message role="user"></message>
    <message role="assistant"></message>
    <message role="developer"></message>
  </messages>
  <plugins group="main">
    <plugin name="filepu" />
    <plugin name="timepu" />
  </plugins>
  <plugins group="alt">
    <plugin name="filepu" />
  </plugins>
</chat>